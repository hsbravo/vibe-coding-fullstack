<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.vibeapp.post.PostTagRepository">

    <!-- 태그 추가 -->
    <insert id="add" parameterType="com.example.vibeapp.post.PostTag">
        INSERT INTO POST_TAGS (POST_NO, TAG_NAME)
        VALUES (#{postNo}, #{tagName})
    </insert>

    <!-- 태그 삭제 (ID 기준) -->
    <delete id="deleteById" parameterType="long">
        DELETE FROM POST_TAGS WHERE ID = #{id}
    </delete>

    <!-- 게시글 기준으로 태그 전체 삭제 -->
    <delete id="deleteByPostNo" parameterType="long">
        DELETE FROM POST_TAGS WHERE POST_NO = #{postNo}
    </delete>

    <!-- 게시글의 태그 목록 조회 -->
    <select id="findByPostNo" parameterType="long" resultType="com.example.vibeapp.post.PostTag">
        SELECT * FROM POST_TAGS WHERE POST_NO = #{postNo} ORDER BY ID
    </select>

</mapper>
